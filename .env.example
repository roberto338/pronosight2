# ══════════════════════════════════════════════
# PronoSight — Configuration
# ══════════════════════════════════════════════
# Copie ce fichier en .env et remplis tes clés

# Port du serveur (défaut: 3000)
PORT=3000

# ── Clé API Anthropic (OBLIGATOIRE) ──
# console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Clé The Odds API (OPTIONNELLE) ──
# the-odds-api.com → Sign Up → Copy API Key
# 500 requêtes/mois gratuites
ODDS_API_KEY=

# ── Clé football-data.org (OPTIONNELLE) ──
# football-data.org → Register → API Token
# 10 requêtes/minute gratuites
FOOTBALL_DATA_KEY=

# ── Clé API-Football (OPTIONNELLE, pour live) ──
# api-football.com → Dashboard → API Key
LIVE_API_KEY=

# ── Modèle Claude par défaut ──
CLAUDE_MODEL=claude-sonnet-4-5-20250929
